<style>
    .error-page {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 20px;
    }
    .error-page h1 {
        font-family: var(--font-display);
        font-size: 120px;
        color: var(--accent-coral);
        margin-bottom: 20px;
        line-height: 1;
    }
    .error-page h2 {
        font-family: var(--font-display);
        font-size: 24px;
        color: var(--text-primary);
        margin-bottom: 16px;
    }
    .error-page p {
        color: var(--text-secondary);
        font-size: 16px;
        margin-bottom: 40px;
        max-width: 500px;
    }
    .btn-home {
        background: var(--text-primary); 
        color: var(--bg);
        padding: 12px 24px;
        border-radius: var(--radius-btn);
        text-decoration: none;
        font-weight: 600;
        transition: opacity 0.3s;
    }
    .btn-home:hover { opacity: 0.9; }
</style>

<div class="error-page">
    <h1><%= typeof status !== 'undefined' ? status : 500 %></h1>
    <h2>Something went wrong</h2>
    <p><%= typeof message !== 'undefined' ? message : 'An unexpected error occurred.' %></p>
    <a href="/" class="btn-home">Return to Home</a>
</div>
