<link rel="stylesheet" href="/css/about.css">

<div class="about-page">
  <!-- TOP BAR -->
  <header class="top-bar">
    <a href="/" class="btn-back">← Back</a>
    <h1 class="logo">About RoleReady AI</h1>
    <div class="top-bar-right"></div>
  </header>

  <main class="about-content">
    
    <!-- Hero -->
    <section class="about-hero reveal">
      <h1>BUILT FOR THE<br><span>GAP</span> BETWEEN<br>HIRING AND READY</h1>
      <p>Every hire has a different starting point.<br>Generic onboarding ignores that. RoleReady AI doesn't.</p>
    </section>

    <!-- Problem -->
    <section class="about-section problem-section">
      <div class="section-badge reveal">THE PROBLEM</div>
      <div class="stats-grid">
        <div class="problem-stat reveal">
          <div class="big-num">40h</div>
          <div class="stat-desc">Average generic<br>onboarding duration</div>
        </div>
        <div class="problem-stat reveal" style="transition-delay: 0.1s">
          <div class="big-num">68%</div>
          <div class="stat-desc">Of that time spent on<br>already-known content</div>
        </div>
        <div class="problem-stat reveal" style="transition-delay: 0.2s">
          <div class="big-num">$2,400</div>
          <div class="stat-desc">Average cost per<br>onboarding hour wasted</div>
        </div>
      </div>
    </section>

    <!-- How it Works -->
    <section class="about-section logic-section">
      <div class="section-badge reveal">HOW IT WORKS</div>
      <div class="steps-row reveal">
        <div class="step">
          <div class="step-num">01 PARSE</div>
          <div class="step-title">Resume + JD<br>uploaded</div>
          <div class="step-desc">Extracting technical context simultaneously.</div>
        </div>
        <div class="step">
          <div class="step-num">02 DETECT</div>
          <div class="step-title">Skill gaps<br>identified</div>
          <div class="step-desc">Calculating conceptual distance via SBERT embeddings.</div>
        </div>
        <div class="step">
          <div class="step-num">03 PATH</div>
          <div class="step-title">Custom order<br>generated</div>
          <div class="step-desc">Topologically sorting prerequisite graphs correctly.</div>
        </div>
        <div class="step">
          <div class="step-num">04 EXPLAIN</div>
          <div class="step-title">Reasoning<br>surfaced</div>
          <div class="step-desc">Mapping concrete reasoning onto components natively.</div>
        </div>
      </div>
    </section>

    <!-- Differentiators -->
    <section class="about-section diff-section">
      <div class="section-badge reveal">WHAT MAKES IT DIFFERENT</div>
      <div class="diff-grid">
        <div class="differentiator-card reveal">
          <h3>Semantic Matching</h3>
          <p>Not keyword search.<br>SBERT embeddings<br>find meaning.</p>
        </div>
        <div class="differentiator-card reveal" style="transition-delay: 0.1s">
          <h3>Zero Hallucinations</h3>
          <p>Fixed course catalog.<br>AI picks, never<br>invents.</p>
        </div>
        <div class="differentiator-card reveal" style="transition-delay: 0.2s">
          <h3>Reasoning Trace</h3>
          <p>Every module<br>explained with<br>WHY it's here.</p>
        </div>
      </div>
    </section>

    <!-- Tech Stack -->
    <section class="about-section stack-section">
      <div class="section-badge reveal">THE STACK</div>
      <div class="stack-pills">
        <span class="stack-pill reveal">Python</span>
        <span class="stack-pill reveal">FastAPI</span>
        <span class="stack-pill reveal">SBERT</span>
        <span class="stack-pill reveal">LLaMA 3.1</span>
        <span class="stack-pill reveal">Groq</span>
        <span class="stack-pill reveal">NetworkX</span>
        <span class="stack-pill reveal">Node.js</span>
        <span class="stack-pill reveal">EJS</span>
      </div>
    </section>

    <!-- Footer -->
    <footer class="about-footer reveal">
      <div class="footer-credit">Built for IISc Bangalore Hackathon 2025<br>Adaptive Onboarding Challenge</div>
    </footer>
  </main>
</div>
<script src="/js/about.js"></script>
